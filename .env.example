# Copy this file to .env and edit as needed.
# .env is gitignored — never commit secrets.

# Port to expose on the host machine (default: 8635)
HOST_PORT=8635

# Set to 1 to enable verbose server logging (default: 0 = quiet)
SERVER_VERBOSE=0

# Override the braille event log path (optional)
# BRAILLE_LOG_PATH=/project/data/logs/braille_send_events.jsonl

# Host path for persistent data (models, renders, logs, SQLite DB).
# Local dev default is ./data (relative to docker-compose.yml).
# On the hosted server set this to the NFS share path, e.g.:
#   DATA_DIR=/projects/make4all/cad-a11y
DATA_DIR=./data

# --- Workshop STL ingest (/ingest + /workshop) ---

# Maximum upload/ingest body size in megabytes (default: 100). Larger requests are
# rejected with HTTP 413.
MAX_UPLOAD_MB=100

# Set to 1 to allow /ingest to open the model in a browser window on THIS machine.
# It only takes effect when the caller also passes open=1, so a remote tool cannot
# open windows here on its own. For single-station setups where the braille display
# is attached to the server. Default 0.
INGEST_OPEN_ON_HOST=0

# Public base URL used to build the workshop links returned by /ingest, when the
# externally reachable URL differs from what the server sees (reverse proxy / Docker).
# Example: PUBLIC_BASE_URL=https://cad-a11y.example.org
# PUBLIC_BASE_URL=
